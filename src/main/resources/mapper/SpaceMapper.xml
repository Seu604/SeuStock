<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.seu.seustock.mapper.SpaceMapper">

    <resultMap id="SpaceResultMap" type="SpaceDTO">
        <id     property="id"         column="id"/>
        <result property="externalId" column="external_id"/>
        <result property="userId"     column="user_id"/>
        <result property="name"       column="name"/>
        <result property="createdAt"  column="created_at"/>
    </resultMap>

    <insert id="insertSpace" parameterType="SpaceDTO"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO spaces (user_id, name)
        VALUES (#{userId}, #{name})
    </insert>

    <select id="findByExternalId" parameterType="java.util.UUID" resultMap="SpaceResultMap">
        SELECT id, external_id, user_id, name, created_at
        FROM spaces
        WHERE external_id = #{externalId}
    </select>

    <select id="findById" parameterType="long" resultMap="SpaceResultMap">
        SELECT id, external_id, user_id, name, created_at
        FROM spaces
        WHERE id = #{id}
    </select>

    <select id="findByUserId" parameterType="long" resultMap="SpaceResultMap">
        SELECT id, external_id, user_id, name, created_at
        FROM spaces
        WHERE user_id = #{userId}
    </select>

    <select id="findByUserIdWithOptions" resultMap="SpaceResultMap">
        SELECT id, external_id, user_id, name, created_at
        FROM spaces
        WHERE user_id = #{userId}
        <if test="keyword != null and keyword != ''">
          AND name LIKE CONCAT('%', #{keyword}, '%')
        </if>
        ORDER BY
        <choose>
            <when test="sortBy == 'oldest'">
                created_at ASC, id ASC
            </when>
            <when test="sortBy == 'name'">
                name ASC, created_at DESC, id DESC
            </when>
            <otherwise>
                created_at DESC, id DESC
            </otherwise>
        </choose>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByUserIdWithOptions" resultType="int">
        SELECT COUNT(*)
        FROM spaces
        WHERE user_id = #{userId}
        <if test="keyword != null and keyword != ''">
          AND name LIKE CONCAT('%', #{keyword}, '%')
        </if>
    </select>

    <update id="updateSpace" parameterType="SpaceDTO">
        UPDATE spaces
        SET name = #{name}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM spaces
        WHERE id = #{id}
    </delete>

</mapper>
